---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Photography">
  <div class="container" style="padding-bottom: 1rem;">
    <h1 class="page-title">Photography</h1>
    <span class="page-title-jp">写真</span>
  </div>
  <div class="photo-gallery" style="padding: 0 1.5rem 2rem;">
    <div class="row">
      <img src="/images/snap/pano1.jpg" class="pano" alt="Panoramic photo" />
      <div class="column">
        <img src="/images/snap/dark15.jpg" alt="" />
        <img src="/images/snap/dark6.JPG" alt="" />
        <img src="/images/snap/dark4.jpg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/dark2.jpeg" alt="" />
        <img src="/images/snap/dark5.jpg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/dark1.jpg" alt="" />
        <img src="/images/snap/lay2.jpeg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/dark3.JPG" alt="" />
        <img src="/images/snap/dark8.jpg" alt="" />
      </div>
    </div>
    <div class="row">
      <img src="/images/snap/pano2.jpg" class="pano" alt="Panoramic photo" />
      <div class="column">
        <img src="/images/snap/23.jpg" alt="" />
        <img src="/images/snap/9.jpg" alt="" />
        <img src="/images/snap/3.jpg" alt="" />
        <img src="/images/snap/10.jpg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/24.jpg" alt="" />
        <img src="/images/snap/22.jpg" alt="" />
        <img src="/images/snap/5.jpg" alt="" />
        <img src="/images/snap/28.jpg" alt="" />
        <img src="/images/snap/dark14.jpg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/18.jpg" alt="" />
        <img src="/images/snap/7.jpg" alt="" />
        <img src="/images/snap/26.jpg" alt="" />
        <img src="/images/snap/13.jpg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/27.jpg" alt="" />
        <img src="/images/snap/17.jpg" alt="" />
        <img src="/images/snap/21.jpg" alt="" />
        <img src="/images/snap/11.jpg" alt="" />
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <img id="lightbox-img" src="" alt="Enlarged photo" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox')!;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

    document.querySelectorAll('.photo-gallery .column img, .photo-gallery .pano').forEach((img) => {
      img.addEventListener('click', () => {
        lightboxImg.src = (img as HTMLImageElement).src;
        lightbox.classList.add('active');
      });
    });

    lightbox.addEventListener('click', () => {
      lightbox.classList.remove('active');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') lightbox.classList.remove('active');
    });
  </script>
</BaseLayout>
