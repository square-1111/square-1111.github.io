---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Photography">
  <div class="photo-gallery container-fluid">
    <div class="row">
      <img src="/images/snap/pano1.jpg" class="pano" alt="Panoramic photo 1" />
      <div class="column">
        <img src="/images/snap/dark15.jpg" alt="" />
        <img src="/images/snap/dark6.JPG" alt="" />
        <img src="/images/snap/dark4.jpg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/dark2.jpeg" alt="" />
        <img src="/images/snap/dark5.jpg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/dark1.jpg" alt="" />
        <img src="/images/snap/lay2.jpeg" alt="" />
      </div>
      <div class="column">
        <img src="/images/snap/dark3.JPG" alt="" />
        <img src="/images/snap/dark8.jpg" alt="" />
      </div>
    </div>
    <div class="row">
      <img src="/images/snap/pano2.jpg" class="pano" alt="Panoramic photo 2" />
      <div class="column">
