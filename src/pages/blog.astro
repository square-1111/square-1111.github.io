---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog">
  <article class="page container">
    <header class="page-header">
      <h1 class="page-title">Blog</h1>
      <span class="page-subtitle">Correspondencia &bull; 100 Days of Writing</span>
    </header>
    <section class="stamp">
      <div class="stamp-inner">
        <span class="postal-label">Correo Aereo</span>
        <span class="stamp-value">10<small>c</small></span>
        <div class="post-list">
          {posts.map((post) => (
            <article class="post-item">
              <span class="post-meta date-label">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })}
              </span>
              <div class="article-title">
                <a class="post-link" href={`/blog/${post.id}/`}>{post.data.title}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
