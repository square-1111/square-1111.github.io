---
const navLinks = [
  { href: '/about', label: 'About', jp: '自己紹介' },
  { href: '/blog', label: 'Blogs', jp: 'ブログ' },
  { href: '/photos', label: 'Photography', jp: '写真' },
  { href: '/rss.xml', label: 'RSS', jp: '' },
];
---

<div class="airmail-stripe"></div>
<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="nav-brand">
      <h1>Tezuesh<span class="brand-right"> Varshney</span></h1>
      <span class="nav-brand-jp">東京より</span>
    </a>
    <button class="nav-toggle" aria-label="Toggle navigation" id="nav-toggle">
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
    </button>
    <div class="nav-links" id="nav-links">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="nav-link">{label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-links')?.classList.toggle('open');
  });
</script>
